{
  "entities": {
    "Card": {
      "title": "Flashcard",
      "description": "A flashcard for memorizing lyrics phrases using FSRS.",
      "type": "object",
      "properties": {
        "originalPhrase": { "type": "string" },
        "translatedPhrase": { "type": "string" },
        "explanation": { "type": "string", "description": "AI-generated context, idioms, or grammar notes." },
        "parentOriginalPhrase": { "type": "string", "description": "Original line or sentence this component belongs to." },
        "status": { "type": "string", "enum": ["new", "known", "studying"] },
        "trackTitle": { "type": "string" },
        "artist": { "type": "string" },
        "sourceLanguage": { "type": "string" },
        "userId": { "type": "string" },
        "due": { "type": "string", "format": "date-time" },
        "state": { "type": "number", "description": "FSRS State (0: New, 1: Learning, 2: Review, 3: Relearning)" },
        "last_review": { "type": "string", "format": "date-time" },
        "elapsed_days": { "type": "number" },
        "scheduled_days": { "type": "number" },
        "stability": { "type": "number" },
        "difficulty": { "type": "number" },
        "reps": { "type": "number" },
        "lapses": { "type": "number" },
        "learning_steps": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["originalPhrase", "translatedPhrase", "userId", "state", "createdAt", "due", "status", "trackTitle", "artist", "sourceLanguage"]
    },
    "TrackMeaning": {
      "title": "Track Meaning",
      "description": "Unified cache for track meaning in multiple languages and original language detection.",
      "type": "object",
      "properties": {
        "trackKey": { "type": "string" },
        "title": { "type": "string" },
        "artists": { "type": "array", "items": { "type": "string" } },
        "artistId": { "type": "string" },
        "albumName": { "type": "string" },
        "albumId": { "type": "string" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "appleMusicUrl": { "type": "string" },
        "itunesId": { "type": "number" },
        "itunesTrackId": { "type": "string" },
        "originalLanguage": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "meanings": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "es": { "type": "string" },
            "ru": { "type": "string" },
            "pl": { "type": "string" }
          },
          "required": ["en", "es", "ru", "pl"]
        },
        "promptVersion": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trackKey", "title", "artists", "originalLanguage", "meanings", "promptVersion", "createdAt"]
    },
    "CompleteAnalysisCache": {
      "title": "Complete Analysis Cache",
      "description": "Cached result of completeLyricsAnalysis LLM call.",
      "type": "object",
      "properties": {
        "result": { "type": "object" },
        "trackKey": { "type": "string" },
        "lyricsHash": { "type": "string" },
        "targetLanguage": { "type": "string" },
        "promptVersion": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["result", "trackKey", "lyricsHash", "targetLanguage", "promptVersion", "createdAt"]
    },
    "LineTranslationsCache": {
      "title": "Line Translations Cache",
      "description": "Cached line translations (unique list + sequence order) in three languages (en, es, ru).",
      "type": "object",
      "properties": {
        "uniqueLines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "originalText": { "type": "string" },
              "language": { "type": "string" },
              "type": { "type": "string" },
              "translations": {
                "type": "object",
                "properties": {
                  "en": { "type": "string" },
                  "es": { "type": "string" },
                  "ru": { "type": "string" }
                },
                "required": ["en", "es", "ru"]
              }
            },
            "required": ["originalText", "language", "type", "translations"]
          }
        },
        "lineOrder": { "type": "array", "items": { "type": "integer" } },
        "trackKey": { "type": "string" },
        "lyricsHash": { "type": "string" },
        "promptVersion": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uniqueLines", "lineOrder", "trackKey", "lyricsHash", "promptVersion", "createdAt"]
    },
    "PhraseAnalysisCache": {
      "title": "Phrase Analysis Cache",
      "description": "Cached phrase segments analysis for a target language.",
      "type": "object",
      "properties": {
        "phrases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "language": { "type": "string" },
              "translation": { "type": "string" },
              "explanation": { "type": "string" },
              "lineIndex": { "type": "integer" }
            },
            "required": ["text", "language", "translation", "explanation", "lineIndex"]
          }
        },
        "trackKey": { "type": "string" },
        "lyricsHash": { "type": "string" },
        "targetLanguage": { "type": "string" },
        "promptVersion": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phrases", "trackKey", "lyricsHash", "targetLanguage", "promptVersion", "createdAt"]
    }
  },
  "firestore": {
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Collection of user flashcards."
    },
    "/track_meanings/{trackKey}": {
      "schema": "TrackMeaning",
      "description": "Cache for track meanings and detected languages."
    },
    "/complete_analysis_cache/{cacheId}": {
      "schema": "CompleteAnalysisCache",
      "description": "Cache for complete lyrics analysis."
    },
    "/line_translations_cache/{cacheId}": {
      "schema": "LineTranslationsCache",
      "description": "Cache for line-by-line lyrics translations."
    },
    "/phrase_analysis_cache/{cacheId}": {
      "schema": "PhraseAnalysisCache",
      "description": "Cache for phrase segments extraction and grammatical analysis."
    }
  }
}
