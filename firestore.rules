rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidCard(data) {
      // Basic identity and integrity
      return data.userId == request.auth.uid &&
             data.originalPhrase is string && data.originalPhrase.size() <= 1000 &&
             data.status in ['new', 'known', 'studying'] &&
             // Ensure it has the FSRS required fields without strict size check
             data.keys().hasAll(['originalPhrase', 'translatedPhrase', 'trackTitle', 'artist', 'sourceLanguage', 'status', 'userId', 'due', 'state', 'reps', 'lapses', 'stability', 'difficulty', 'elapsed_days', 'scheduled_days', 'createdAt', 'updatedAt']);
    }

    function isValidCompleteAnalysisCache(data) {
      return data.result is map && 
             data.trackKey is string && 
             data.lyricsHash is string &&
             data.targetLanguage is string &&
             data.promptVersion is number &&
             data.createdAt == request.time;
    }

    function isValidTrackMeaning(data) {
      return data.trackKey is string && 
             data.title is string && 
             data.artists is list &&
             data.originalLanguage is string &&
             data.meanings is map &&
             data.promptVersion is number &&
             data.createdAt == request.time;
    }

    match /cards/{cardId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || incoming().userId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /track_meanings/{trackKey} {
      allow get, list: if true;
      allow create: if isValidTrackMeaning(incoming());
      allow update, delete: if false;
    }

    match /complete_analysis_cache/{cacheId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCompleteAnalysisCache(incoming());
      allow update, delete: if false;
    }
  }
}
