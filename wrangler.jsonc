{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lyrify-v2",
  "compatibility_date": "2026-05-18",
  "main": "./src/worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "assets",
    "run_worker_first": true,
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
